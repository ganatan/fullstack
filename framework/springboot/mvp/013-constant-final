## Variante ultra simple sans classe modèle

```java
package com.example.demo.controllers;

import com.example.demo.constants.TestConstants;
import java.util.LinkedHashMap;
import java.util.Map;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RestController;

@RestController
public class TestController {

    @GetMapping("/test/constants-map")
    public Map<String, Object> testConstantsMap() {
        final String localValue = "valeur locale final";

        Map<String, Object> response = new LinkedHashMap<>();
        response.put("applicationName", TestConstants.APPLICATION_NAME);
        response.put("defaultProfile", TestConstants.DEFAULT_PROFILE);
        response.put("defaultPort", TestConstants.DEFAULT_PORT);
        response.put("status", TestConstants.STATUS_OK);
        response.put("message", TestConstants.MESSAGE);
        response.put("localValue", localValue);
        return response;
    }
}
```

