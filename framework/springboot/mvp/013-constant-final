## Controller `TestController`

```java
package com.example.demo.controllers;

import com.example.demo.constants.TestConstants;
import com.example.demo.model.TestResponse;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RestController;

@RestController
public class TestController {

    private final String controllerName = "TestController";

    @GetMapping("/test/constants")
    public TestResponse testConstants() {
        final String localValue = "valeur locale final";

        return new TestResponse(
            TestConstants.APPLICATION_NAME,
            TestConstants.DEFAULT_PROFILE,
            TestConstants.DEFAULT_PORT,
            TestConstants.STATUS_OK,
            TestConstants.MESSAGE,
            localValue
        );
    }

    @GetMapping("/test/final")
    public String testFinal() {
        final String message = "une variable final ne peut plus etre reassignee";
        return message;
    }

    @GetMapping("/test/controller-name")
    public String getControllerName() {
        return controllerName;
    }
}
```

